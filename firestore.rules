rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a robust administrative and public content management system for StudioForge. 
     * It relies on Authorization Independence through denormalization and structural segregation.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "sajjadsaffan634@gmail.com"
      );
    }

    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    function isExistingResourceOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    // --- Collection Rules ---

    match /adminUsers/{adminUid} {
      allow get, list: if isOwner(adminUid) || isAdmin();
      allow create: if isOwner(adminUid) || isAdmin();
      allow update, delete: if isOwner(adminUid) || isAdmin();
    }

    match /admin_roles/{adminUid} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin() || (isSignedIn() && request.auth.token.email == "sajjadsaffan634@gmail.com");
    }

    match /blogCategories/{categoryId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /blogTags/{tagId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /admin_blog_posts/{blogPostId} {
      allow get, list: if isAdmin() || (resource != null && isOwner(resource.data.authorId));
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.authorId == request.auth.uid);
      allow update, delete: if isExistingAdmin() || (resource != null && isOwner(resource.data.authorId));
    }

    match /public_blog_posts/{blogPostId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /public_blog_posts/{blogPostId}/comments/{commentId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /admin_inbox/comments/{commentId} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow update, delete: if isExistingAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }
  }
}
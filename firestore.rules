
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid)) ||
        request.auth.token.email == "sajjadsaffan634@gmail.com"
      );
    }

    match /adminUsers/{uid} {
      allow read: if isAdmin() || (request.auth.uid == uid);
      allow write: if isAdmin() || (request.auth.uid == uid);
    }

    match /admin_roles/{uid} {
      allow read: if isAdmin();
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == "sajjadsaffan634@gmail.com");
    }

    match /admin_blog_posts/{postId} {
      allow read, write: if isAdmin();
    }

    match /public_blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /inquiries/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /bookings/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}

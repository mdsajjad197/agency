
{
  "entities": {
    "AdminUser": {
      "title": "AdminUser",
      "type": "object",
      "description": "Administrator account details.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "role"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "type": "object",
      "description": "Studio blog content.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "featuredImageUrl": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "slug", "content", "status", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "type": "object",
      "description": "Client project leads.",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "serviceRequired": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "converted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientName", "clientEmail", "message", "status", "createdAt"]
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "Appointment bookings.",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientName", "clientEmail", "date", "time", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/adminUsers/{uid}": { "schema": "AdminUser", "description": "Admin profiles" },
    "/admin_roles/{uid}": { "schema": "object", "description": "Authorization flags" },
    "/public_blog_posts/{postId}": { "schema": "BlogPost", "description": "Live articles" },
    "/admin_blog_posts/{postId}": { "schema": "BlogPost", "description": "Master articles" },
    "/inquiries/{id}": { "schema": "Inquiry", "description": "Leads" },
    "/bookings/{id}": { "schema": "Booking", "description": "Appointments" }
  }
}
